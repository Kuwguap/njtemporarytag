# Admin dashboard password (required for /admin access)
ADMIN_PASSWORD=

# JWT secret for admin session (change in production)
JWT_SECRET=

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# Supabase (optional - uses file storage when not set)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=

# Public URL for redirects (e.g. https://your-app.onrender.com)
APP_URL=
